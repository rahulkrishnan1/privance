{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "dom", "dom.iterable"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./src/*"]
    },
    "types": ["vite/client"]
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.mts"],
  "exclude": [
    "node_modules",
    "out",
    "src/sw-src.ts",
    "src/routes/app/_app/-veil-start.browser.test.tsx",
    "src/routes/-unlock-biometric.browser.test.tsx"
  ]
}

# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# playwright
/playwright-report/
/test-results/
/playwright/.cache/
.playwright-fixtures.json

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Capacitor — iOS (mirrors ios/.gitignore; listed here for root-level git)
ios/App/Pods/
ios/App/App.xcworkspace/xcuserdata/
ios/App/build/
ios/DerivedData/

# Capacitor — Android (mirrors android/.gitignore; listed here for root-level git)
android/.gradle/
android/app/build/
android/build/
android/local.properties
android/captures/
android/app/release/

# Vitest browser-mode transient output
.vitest-attachments/
**/__screenshots__/

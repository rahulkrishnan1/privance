{
  "name": "@privance/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/build-sim-worker.mjs && next dev --webpack --port 8081",
    "build:sim-worker": "node scripts/build-sim-worker.mjs",
    "prebuild": "node scripts/build-sim-worker.mjs",
    "build": "next build --webpack",
    "start": "next start --port 8081",
    "typecheck": "tsc --noEmit",
    "pretest": "node scripts/build-sim-worker.mjs",
    "test": "vitest run",
    "cap:sync": "next build && cap sync",
    "cap:ios": "next build && cap sync ios && cap open ios",
    "cap:android": "next build && cap sync android && cap open android",
    "e2e": "playwright test",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui",
    "e2e:install": "playwright install chromium firefox webkit"
  },
  "dependencies": {
    "@capacitor/android": "8.3.4",
    "@capacitor/core": "8.3.4",
    "@capacitor/ios": "8.3.4",
    "@hookform/resolvers": "5.2.2",
    "@privance/core": "workspace:*",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "@tanstack/react-query": "5.101.0",
    "lucide-react": "0.460.0",
    "next": "16.2.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "7.75.0",
    "recharts": "3.8.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@capacitor/cli": "8.3.4",
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "20.19.41",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "@vitest/browser-playwright": "4.1.7",
    "esbuild": "0.28.0",
    "happy-dom": "20.9.0",
    "postgres": "3.4.9",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.7",
    "vitest-browser-react": "2.2.0"
  }
}

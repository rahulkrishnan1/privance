# Copy to .env and fill in real values before running.

# PostgreSQL connection string.
DATABASE_URL=postgres://privance:privance@localhost:5432/privance

# Listening port. Defaults to 3000.
PORT=3000

# development | production. "production" enables the Secure cookie flag.
NODE_ENV=development

# Base64-encoded secret (>=32 bytes) used for username-enumeration prevention
# (fake KDF salt derivation) and IP hashing in rate-limit counters.
# Generate: openssl rand -base64 48
ENUMERATION_SECRET=

# Comma-separated usernames permitted to sign up.
# Leave empty to allow open registration (default for local dev).
SIGNUP_ALLOWLIST=

# Comma-separated CORS origins the server will accept requests from.
#
#  Local web dev:           http://localhost:8081
#  iOS Capacitor WebView:   capacitor://localhost
#  Android Capacitor WebView: https://localhost
#  Production PWA:          https://privance.app
#
# Example (all at once):
#   ALLOWED_ORIGINS=http://localhost:8081,capacitor://localhost,https://localhost,https://privance.app
ALLOWED_ORIGINS=http://localhost:8081

# (Optional) Path to a directory containing a "postgres_password" file
# (Docker secrets pattern). Overrides the password in DATABASE_URL when set.
# PRIVANCE_SECRETS_DIR=

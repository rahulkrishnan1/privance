{
  "name": "@privance/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "bun": ">=1.3.14"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "start": "bun src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile=dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "mint:invite": "bun scripts/mint-invite.ts"
  },
  "dependencies": {
    "@noble/hashes": "2.2.0",
    "@privance/core": "workspace:*",
    "drizzle-orm": "0.45.2",
    "hash-wasm": "4.12.0",
    "hono": "4.12.28",
    "pino": "10.3.1",
    "postgres": "3.4.9"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "drizzle-kit": "0.31.10",
    "typescript": "7.0.2"
  }
}

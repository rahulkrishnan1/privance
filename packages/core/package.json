{
  "name": "@privance/core",
  "version": "0.0.0",
  "private": true,
  "sideEffects": false,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./crypto": "./src/crypto/index.ts",
    "./decimal": "./src/decimal/index.ts",
    "./domain": "./src/domain/index.ts",
    "./networth": "./src/networth/index.ts",
    "./sync": "./src/sync/index.ts",
    "./storage": "./src/storage/index.ts",
    "./audit-events": "./src/audit-events/index.ts",
    "./projection": "./src/projection/index.ts"
  },
  "scripts": {
    "build": "node scripts/verify-dataset.mjs && tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/ciphers": "2.2.0",
    "@noble/hashes": "2.2.0",
    "@scure/bip39": "2.2.0",
    "@sqlite.org/sqlite-wasm": "3.53.0-build1",
    "hash-wasm": "4.12.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "4.1.10",
    "fast-check": "4.8.0",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  }
}

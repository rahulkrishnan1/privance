# Copy to /etc/privance/env.d/server.env on the host (mode 600). No secrets in this template.

# PostgreSQL connection string. Do NOT include the password inline in production;
# set PRIVANCE_SECRETS_DIR so the password is read from the mounted Docker secret file.
DATABASE_URL=postgres://privance@postgres:5432/privance

# Listening port. Caddy reverse proxy and the container healthcheck both target this.
# PORT=3000

# Set to "production" on a live host. Note: Secure session cookies are enabled
# for every value except "test" (see server/src/auth/wire.ts).
NODE_ENV=production

# Base64-encoded secret (>=32 bytes) for username-enumeration prevention
# (fake KDF salt derivation) and IP hashing in rate-limit counters. Required.
# Generate: openssl rand -base64 48
ENUMERATION_SECRET=<replace-with-output-of-openssl-rand-base64-48>

# Comma-separated usernames permitted to sign up. Empty/unset means open
# registration. Use INVITE_REQUIRED below for token-gated signup instead.
# Example: SIGNUP_ALLOWLIST=alice,bob
# SIGNUP_ALLOWLIST=

# Invite-only signup. "true" requires a valid invite_token on POST /api/auth/signup.
# Any other value disables the gate.
INVITE_REQUIRED=true

# Comma-separated CORS origins. Required; must include every origin the client loads from.
#   Production PWA:              https://<your-domain>
#   iOS Capacitor WebView:       capacitor://localhost
#   Android Capacitor WebView:   https://localhost
# Example: ALLOWED_ORIGINS=https://<your-domain>,capacitor://localhost,https://localhost
ALLOWED_ORIGINS=https://<your-domain>

# Directory containing the "postgres_password" file (Docker secrets pattern).
# Server and server-migrate read $PRIVANCE_SECRETS_DIR/postgres_password and append
# it to DATABASE_URL at connect time. compose.prod.yaml sets this in the container
# environment, which overrides any value here; shown for reference only.
# PRIVANCE_SECRETS_DIR=/run/secrets

# Price-feed provider for asset price lookups. Valid: yahoo, coingecko, fake.
# Defaults to yahoo. "fake" is local-testing only.
# PRICE_PROVIDER=yahoo

# Comma-separated tickers to treat as unknown when PRICE_PROVIDER=fake.
# PRICE_FAKE_UNKNOWN=

# pino log level: trace, debug, info, warn, error, fatal, silent. Defaults to info.
# LOG_LEVEL=info

# Login rate-limit overrides. Defaults: 5 attempts per username, 20 per source IP.
# Increase only when hosting behind a NAT that aggregates many users onto one IP.
# RATE_LIMIT_LOGIN_PER_USERNAME=5
# RATE_LIMIT_LOGIN_PER_IP=20

# Copy to /etc/privance/env.d/caddy.env on the host (mode 600). No secrets in this template.

# Primary domain for the instance (without www prefix).
DOMAIN=<your-domain>

# www subdomain. Caddy serves apex and www from one site block (single SAN cert).
WWW_DOMAIN=www.<your-domain>

# Email address for Let's Encrypt ACME account registration and expiry notices.
ACME_EMAIL=<operator-email>

# Leave empty in production. Setting this to "auto_https off" disables TLS entirely
# and is for local smoke-testing only. Never set in a public deployment.
LOCAL_HTTP_ONLY=

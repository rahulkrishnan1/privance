# Copy to /etc/privance/env.d/restic.env on the host (mode 600). No secrets in this template.

# Backblaze B2 application key credentials scoped to the backup bucket.
# Obtain from the Backblaze console: App Keys > Add a New Application Key.
B2_ACCOUNT_ID=<keyID from privance-restic-prod>
B2_ACCOUNT_KEY=<applicationKey from privance-restic-prod>

# restic repository URL. The path component (/restic) is the prefix within the bucket.
RESTIC_REPOSITORY=b2:<your-bucket-name>:/restic

# The repository encryption password is NOT set here. It is read from the Docker
# secret file mounted at /run/secrets/restic_password (see compose.prod.yaml).
# Write the password to /etc/privance/env.d/restic_password (mode 600).
# WARNING: if this password is lost, every snapshot is permanently unrecoverable.
RESTIC_PASSWORD_FILE=/run/secrets/restic_password

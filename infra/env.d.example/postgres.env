# Copy to /etc/privance/env.d/postgres.env on the host (mode 600). No secrets in this template.

# Database name and superuser for the privance PostgreSQL instance.
# These must match the values in server.env's DATABASE_URL.
POSTGRES_USER=privance
POSTGRES_DB=privance

# The password is NOT set here. It is read from the Docker secret file
# mounted at /run/secrets/postgres_password (see compose.prod.yaml).
# Write the password to /etc/privance/env.d/postgres_password (mode 600)
# and the official postgres image will read it via POSTGRES_PASSWORD_FILE.
POSTGRES_PASSWORD_FILE=/run/secrets/postgres_password

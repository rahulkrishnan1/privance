# {$LOCAL_HTTP_ONLY} is empty in production; "auto_https off" only for local smoke (never in prod).
{
	email {$ACME_EMAIL}
	{$LOCAL_HTTP_ONLY}
	log default {
		output stderr
		format console
		level INFO
	}
}

# Single site block covering apex + www produces a SAN cert for both hostnames.
{$DOMAIN}, {$WWW_DOMAIN} {
	encode gzip zstd

	# Scope security headers to non-API responses: hono/secure-headers already
	# emits HSTS, CSP, X-Content-Type-Options, and X-Frame-Options on /api/*,
	# and duplicates are interpreted as the most-restrictive intersection.
	@notapi {
		not path /api/*
	}

	header @notapi {
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		X-Content-Type-Options nosniff
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		X-Frame-Options DENY
		# 'wasm-unsafe-eval': Argon2id (hash-wasm) and SQLite (sqlite-wasm) load
		#   WebAssembly; without this Chromium blocks every WebAssembly.instantiate
		#   and the client crypto path fails. This is the narrowest CSP knob that
		#   re-enables WASM and does NOT permit `eval`.
		# The Vite SPA ships a single external module script and no inline scripts,
		#   so script-src omits 'unsafe-inline'.
		# worker-src 'self' blob:: SQLite worker is created from a blob URL.
		Content-Security-Policy "default-src 'self'; script-src 'self' 'wasm-unsafe-eval'; worker-src 'self' blob:; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'; upgrade-insecure-requests"
	}

	# Preserve the /api prefix: Hono feature routers are mounted at /api/auth,
	# /api/sync, etc. Using `handle` (not `handle_path`) avoids stripping it.
	handle /api/* {
		reverse_proxy server:3000
	}

	# Legacy deep-link compatibility: the four (app) segments moved from
	# /, /accounts, /holdings, /settings to /app/* in the route restructure.
	# Without these, existing bookmarks and pre-rename PWA start_urls 404.
	redir /accounts /app/accounts/ permanent
	redir /accounts/ /app/accounts/ permanent
	redir /holdings /app/holdings/ permanent
	redir /holdings/ /app/holdings/ permanent
	redir /settings /app/settings/ permanent
	redir /settings/ /app/settings/ permanent

	# Single-page app: serve the requested file if it exists, otherwise fall back
	# to index.html so client-routed deep links and hard refreshes resolve.
	handle {
		root * /srv/web
		try_files {path} /index.html
		file_server
	}
}
